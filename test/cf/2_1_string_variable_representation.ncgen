netcdf 2_1_string_variable_representation {
dimensions:
  strings = 6 ;
  strlen = 10 ;
variables:
  char char_variable(strings,strlen) ;
    char_variable:long_name = "strings of type char" ;
  string str_variable(strings) ;
    str_variable:long_name = "strings of type string" ;
data:
  char_variable =
    "alpha",
    "beta",
    "gamma",
    "delta",
    "epsilon",
    "zeta" ;
  str_variable =
    "alpha",
    "beta",
    "gamma",
    "delta",
    "epsilon",
    "zeta" ;
}
